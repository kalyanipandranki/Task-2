from flask import Flask

app = Flask(__name__)

@app.route("/")
def home():
    return """
    <!DOCTYPE html>
    <html>
    <head>
        <title>Flask Task 2</title>

        <style>
            body{
                font-family: Arial, sans-serif;
                background:#f4f4f4;
                margin:0;
            }

            header{
                background:#007BFF;
                color:white;
                text-align:center;
                padding:20px;
            }

            nav{
                background:#333;
                padding:15px;
                text-align:center;
            }

            nav a{
                color:white;
                text-decoration:none;
                margin:20px;
                font-size:18px;
            }

            nav a:hover{
                color:yellow;
            }

            .container{
                width:80%;
                margin:30px auto;
                background:white;
                padding:30px;
                border-radius:10px;
                box-shadow:0 0 10px gray;
            }

            h2{
                color:#007BFF;
            }

            button{
                background:#007BFF;
                color:white;
                border:none;
                padding:10px 20px;
                border-radius:5px;
                cursor:pointer;
            }

            button:hover{
                background:#0056b3;
            }

            footer{
                background:#222;
                color:white;
                text-align:center;
                padding:15px;
                margin-top:30px;
            }
        </style>

    </head>

    <body>

    <header>
        <h1>Welcome to My Flask App</h1>
        <p>Task 2 - Introduction to Python and Flask</p>
    </header>

    <nav>
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
    </nav>

    <div class="container">

        <h2>Home Page</h2>

        <p>
        This webpage is created using Python Flask.
        It demonstrates routing and a simple web server.
        </p>

        <button>Learn Flask</button>

    </div>

    <footer>
        © 2026 Flask Demo
    </footer>

    </body>
    </html>
    """

@app.route("/about")
def about():
    return """
    <h1>About Us</h1>
    <p>This is the About Page.</p>
    <a href="/">Go Back Home</a>
    """

@app.route("/contact")
def contact():
    return """
    <h1>Contact Us</h1>
    <p>Email: demo@gmail.com</p>
    <a href="/">Go Back Home</a>
    """

if __name__ == "__main__":
    app.run(debug=True)